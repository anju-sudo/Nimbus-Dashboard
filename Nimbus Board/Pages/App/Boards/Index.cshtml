@page "/app/boards"
@model Nimbus_Board.Pages.App.Boards.IndexModel

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Boards</h1>
    <p class="text-sm text-slate-500">Kanban boards across your projects</p>
</div>

<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    @foreach (var board in Model.Boards)
    {
        <a href="/app/boards/@board.Id" class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-indigo-200">
            <h2 class="text-lg font-semibold text-slate-900">@board.Name</h2>
            <p class="text-sm text-slate-500">@board.ProjectKey · @board.ProjectName</p>
            <p class="mt-3 text-xs text-slate-400">@board.IssueCount issues</p>
        </a>
    }
</div>
