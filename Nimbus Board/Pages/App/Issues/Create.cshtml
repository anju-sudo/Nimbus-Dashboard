@page "/app/issues/create"
@model Nimbus_Board.Pages.App.Issues.CreateModel
@{
    Layout = null;
}

<div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/40 p-4" onclick="if(event.target===this)this.remove()">
    <div class="w-full max-w-lg rounded-2xl bg-white p-6 shadow-xl" onclick="event.stopPropagation()">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Create issue</h2>
            <button type="button" onclick="this.closest('.fixed').remove()" class="text-slate-400">✕</button>
        </div>
        <form method="post" class="space-y-4">
            <input type="hidden" asp-for="Input.ProjectId" />
            <input type="hidden" asp-for="Input.BoardColumnId" />
            <div>
                <label class="mb-1 block text-sm font-medium">Title</label>
                <input asp-for="Input.Title" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required />
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium">Description</label>
                <textarea asp-for="Input.Description" rows="3" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="mb-1 block text-sm font-medium">Type</label>
                    <select asp-for="Input.Type" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Task</option>
                        <option>Bug</option>
                        <option>Story</option>
                    </select>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium">Priority</label>
                    <select asp-for="Input.Priority" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option>Lowest</option>
                        <option>Low</option>
                        <option selected>Medium</option>
                        <option>High</option>
                        <option>Highest</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="mb-1 block text-sm font-medium">Story points</label>
                    <input asp-for="Input.StoryPoints" type="number" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium">Due date</label>
                    <input asp-for="Input.DueDate" type="date" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="mb-1 block text-sm font-medium">Assignee</label>
                    <input asp-for="Input.AssigneeName" value="Anjumol Babu" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium">Initials</label>
                    <input asp-for="Input.AssigneeInitials" value="AB" maxlength="3" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
                </div>
            </div>
            <button type="submit" class="w-full rounded-xl bg-indigo-600 py-2.5 text-sm font-medium text-white">Create issue</button>
        </form>
    </div>
</div>
