@model NimbusBoard.Application.Boards.Models.BoardIssueCardViewModel
<div class="issue-card cursor-grab rounded-xl border border-slate-200 bg-white p-3 shadow-sm active:cursor-grabbing"
     data-issue-id="@Model.Id"
     hx-get="/app/issues/@Model.Key?partial=true"
     hx-target="#issue-panel-root"
     hx-swap="innerHTML">
    <div class="mb-2 flex items-center justify-between">
        <span class="text-xs font-semibold text-indigo-600">@Model.Key</span>
        <span class="rounded-full px-2 py-0.5 text-[10px] font-medium @Model.PriorityClass">@Model.Priority</span>
    </div>
    <p class="text-sm text-slate-800">@Model.Title</p>
    @if (!string.IsNullOrEmpty(Model.AssigneeInitials))
    {
        <div class="mt-3 flex justify-end">
            <span class="flex h-7 w-7 items-center justify-center rounded-full text-[10px] font-semibold @Model.AssigneeClass">@Model.AssigneeInitials</span>
        </div>
    }
</div>
