@{
    var title = ViewData["Title"] as string ?? "Nimbus Board";
    var activeNav = ViewData["ActiveNav"] as string ?? "dashboard";
    var unread = ViewData["UnreadNotifications"] as int? ?? 3;
    var userName = ViewData["UserName"] as string ?? "Jordan Silva";
    var userInitials = ViewData["UserInitials"] as string ?? "JS";
    var workspace = ViewData["WorkspaceName"] as string ?? "Acme";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Nimbus Board</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">
<div class="flex min-h-screen">
    <aside class="hidden w-64 shrink-0 flex-col border-r border-slate-200 bg-white lg:flex">
        <div class="border-b border-slate-100 px-6 py-5">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-600 text-sm font-bold text-white">N</div>
                <div>
                    <p class="font-semibold text-slate-900">Nimbus</p>
                    <p class="text-xs text-slate-500">Workspace · @workspace</p>
                </div>
            </div>
        </div>
        <nav class="flex-1 space-y-1 px-3 py-4">
            @{
                string NavClass(string key) => activeNav == key
                    ? "bg-sky-50 text-sky-700"
                    : "text-slate-600 hover:bg-slate-50";
            }
            <a href="/app/dashboard" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("dashboard")">Dashboard</a>
            <a href="/app/my-work" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("my-work")">My Work</a>
            <a href="/app/projects" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("projects")">Projects</a>
            <a href="/app/boards" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("boards")">Boards</a>
            <a href="/app/sprints" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("sprints")">Sprints</a>
            <a href="/app/notifications" class="flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("notifications")">
                <span>Notifications</span>
                @if (unread > 0)
                {
                    <span class="rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white">@unread</span>
                }
            </a>
            <a href="/app/settings" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("settings")">Settings</a>
        </nav>
        <div class="border-t border-slate-100 p-4">
            <div class="flex items-center gap-3 rounded-xl bg-slate-50 px-3 py-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-violet-100 text-sm font-semibold text-violet-700">@userInitials</div>
                <div>
                    <p class="text-sm font-medium text-slate-900">@userName</p>
                    <p class="text-xs text-slate-500">Member</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 overflow-auto">
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
            @RenderBody()
        </div>
    </main>
</div>
@await RenderSectionAsync("Scripts", required: false)
<script src="~/js/search-shortcut.js" asp-append-version="true"></script>
</body>
</html>
