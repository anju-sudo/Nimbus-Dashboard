@{
    var title = ViewData["Title"] as string ?? "Nimbus Board";
    var activeNav = ViewData["ActiveNav"] as string ?? "dashboard";
    var unread = ViewData["UnreadNotifications"] as int? ?? 0;
    var userName = ViewData["UserName"] as string ?? "Anjumol Babu";
    var userInitials = ViewData["UserInitials"] as string ?? "AB";
    var workspace = ViewData["WorkspaceName"] as string ?? "Acme";
    var memberId = ViewData["MemberId"] as int? ?? 1;

    string NavClass(string key) => activeNav == key
        ? "bg-sky-50 text-sky-700"
        : "text-slate-600 hover:bg-slate-50";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Nimbus Board</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900" data-member-id="@memberId">
@Html.AntiForgeryToken()

<div id="sidebar-overlay" class="fixed inset-0 z-40 hidden bg-slate-900/40 lg:hidden" onclick="window.nimbusCloseSidebar()"></div>

<div class="flex min-h-screen">
    <aside id="app-sidebar"
           class="fixed inset-y-0 left-0 z-50 flex w-64 -translate-x-full flex-col border-r border-slate-200 bg-white transition-transform duration-200 lg:static lg:translate-x-0">
        <div class="border-b border-slate-100 px-6 py-5">
            <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-600 text-sm font-bold text-white">N</div>
                    <div>
                        <p class="font-semibold text-slate-900">Nimbus</p>
                        <p class="text-xs text-slate-500">Workspace · @workspace</p>
                    </div>
                </div>
                <button type="button" class="rounded-lg p-2 text-slate-400 hover:bg-slate-50 lg:hidden" onclick="window.nimbusCloseSidebar()" aria-label="Close menu">✕</button>
            </div>
        </div>
        <nav class="flex-1 space-y-1 px-3 py-4">
            <a href="/app/dashboard" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("dashboard")">Dashboard</a>
            <a href="/app/my-work" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("my-work")">My Work</a>
            <a href="/app/projects" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("projects")">Projects</a>
            <a href="/app/boards" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("boards")">Boards</a>
            <a href="/app/sprints" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("sprints")">Sprints</a>
            <a href="/app/notifications" class="flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("notifications")">
                <span>Notifications</span>
                <span id="notification-badge"
                      class="@(unread > 0 ? "" : "hidden") rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"
                      data-count="@unread">@(unread > 0 ? unread.ToString() : "")</span>
            </a>
            <a href="/app/settings" class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium @NavClass("settings")">Settings</a>
        </nav>
        <div class="border-t border-slate-100 p-4">
            <div class="flex items-center gap-3 rounded-xl bg-slate-50 px-3 py-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-violet-100 text-sm font-semibold text-violet-700">@userInitials</div>
                <div>
                    <p class="text-sm font-medium text-slate-900">@userName</p>
                    <p class="text-xs text-slate-500">Member</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 overflow-auto">
        <div class="sticky top-0 z-30 flex items-center gap-3 border-b border-slate-200 bg-slate-50/95 px-4 py-3 backdrop-blur lg:hidden">
            <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" onclick="window.nimbusOpenSidebar()">Menu</button>
            <button type="button" onclick="window.nimbusOpenSearch()"
                    class="flex flex-1 items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-400">
                <span>Search...</span>
                <span class="ml-auto rounded border border-slate-200 px-1.5 text-xs">⌘K</span>
            </button>
        </div>
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
            @RenderBody()
        </div>
    </main>
</div>

<div id="search-modal" class="fixed inset-0 z-50 hidden items-start justify-center bg-slate-900/40 p-4 sm:p-8">
    <div class="w-full max-w-xl rounded-2xl bg-white p-4 shadow-xl">
        <input id="global-search-input"
               type="text"
               name="q"
               placeholder="Search issues, projects, boards..."
               hx-get="/app/search"
               hx-trigger="keyup changed delay:200ms"
               hx-target="#search-results"
               hx-swap="innerHTML"
               class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-indigo-500" />
        <div id="search-results" class="mt-3 max-h-80 overflow-y-auto">
            <p class="px-2 py-4 text-sm text-slate-500">Type to search issues, projects, and boards.</p>
        </div>
        <button type="button" onclick="window.nimbusCloseSearch()" class="mt-3 text-sm text-slate-500">Close (Esc)</button>
    </div>
</div>

<div id="toast-root" class="pointer-events-none fixed bottom-4 right-4 z-50 flex w-80 flex-col gap-2"></div>

@await RenderSectionAsync("Scripts", required: false)
<script src="~/js/search-shortcut.js" asp-append-version="true"></script>
<script src="~/js/notifications-hub.js" asp-append-version="true"></script>
</body>
</html>
