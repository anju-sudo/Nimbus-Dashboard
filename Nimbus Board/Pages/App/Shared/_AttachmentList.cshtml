@model NimbusBoard.Application.Issues.Models.IssueDetailViewModel

@if (!Model.Attachments.Any())
{
    <p class="text-sm text-slate-500">No attachments.</p>
}
else
{
    <ul class="space-y-2">
        @foreach (var file in Model.Attachments)
        {
            <li class="flex items-center justify-between rounded-lg bg-white px-3 py-2 text-sm shadow-sm">
                <a href="@file.Url" target="_blank" class="font-medium text-indigo-600 hover:underline">@file.FileName</a>
                <div class="flex items-center gap-3">
                    <span class="text-xs text-slate-400">@file.TimeAgo</span>
                    <button type="button"
                            hx-delete="/app/issues/attachments/@file.Id"
                            hx-target="#attachments-list-@Model.Key"
                            hx-swap="innerHTML"
                            class="text-xs text-red-500 hover:text-red-700">Delete</button>
                </div>
            </li>
        }
    </ul>
}
