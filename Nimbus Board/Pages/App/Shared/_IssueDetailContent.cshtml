@model NimbusBoard.Application.Issues.Models.IssueDetailViewModel

<div class="mb-6 flex items-start justify-between">
    <div>
        <span class="text-sm font-semibold text-indigo-600">@Model.Key</span>
        <h1 class="mt-1 text-xl font-bold text-slate-900">@Model.Title</h1>
        <p class="text-sm text-slate-500">@Model.ProjectKey · @Model.ProjectName</p>
    </div>
    <button type="button" onclick="this.closest('.fixed')?.remove()" class="text-slate-400 hover:text-slate-600">✕</button>
</div>

<!-- Labels -->
<div class="mb-4">
    <partial name="Shared/_LabelPicker" model="Model" />
</div>

<form method="post" asp-page="/App/Issues/Detail" asp-route-key="@Model.Key" class="mb-6 space-y-4">
    <div>
        <label class="mb-1 block text-sm font-medium">Title</label>
        <input name="title" value="@Model.Title" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required />
    </div>
    <div>
        <label class="mb-1 block text-sm font-medium">Description</label>
        <textarea name="description" rows="4" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">@Model.Description</textarea>
    </div>
    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="mb-1 block text-sm font-medium">Type</label>
            <select name="type" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                @foreach (var t in new[] { "Task", "Bug", "Story" })
                {
                    <option value="@t" selected="@(Model.Type == t)">@t</option>
                }
            </select>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">Priority</label>
            <select name="priority" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                @foreach (var p in new[] { "Lowest", "Low", "Medium", "High", "Highest" })
                {
                    <option value="@p" selected="@(Model.Priority == p)">@p</option>
                }
            </select>
        </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="mb-1 block text-sm font-medium">Story points</label>
            <input name="storyPoints" type="number" value="@Model.StoryPoints" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">Due date</label>
            <input name="dueDate" type="date" value="@(Model.DueDate?.ToString("yyyy-MM-dd"))" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
        </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="mb-1 block text-sm font-medium">Assignee</label>
            <input name="assigneeName" value="@Model.AssigneeName" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">Initials</label>
            <input name="assigneeInitials" value="@Model.AssigneeInitials" maxlength="3" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
        </div>
    </div>
    <div class="flex items-center gap-3 text-sm text-slate-500">
        <span class="rounded-full bg-slate-100 px-3 py-1">Status: @Model.Status</span>
    </div>
    <button type="submit" class="w-full rounded-xl bg-indigo-600 py-2.5 text-sm font-medium text-white">Save changes</button>
</form>

<!-- Attachments -->
<div class="mb-6 rounded-xl border border-slate-100 bg-slate-50 p-4">
    <h3 class="mb-3 text-sm font-semibold text-slate-900">Attachments</h3>
    <div id="attachments-list-@Model.Key">
        <partial name="Shared/_AttachmentList" model="Model" />
    </div>
    <form class="mt-3"
          hx-post="/app/issues/@Model.Key/attachments"
          hx-encoding="multipart/form-data"
          hx-target="#attachments-list-@Model.Key"
          hx-swap="innerHTML">
        <div class="flex gap-2">
            <input type="file" name="file" required class="flex-1 text-sm" />
            <button type="submit" class="rounded-lg bg-white px-3 py-2 text-sm font-medium text-indigo-600 shadow-sm ring-1 ring-slate-200 hover:bg-indigo-50">Upload</button>
        </div>
    </form>
</div>

<!-- Comments -->
<div class="mb-6 rounded-xl border border-slate-100 bg-slate-50 p-4">
    <h3 class="mb-3 text-sm font-semibold text-slate-900">Comments</h3>
    <div id="comments-list-@Model.Key">
        <partial name="Shared/_CommentThread" model="Model.Comments" />
    </div>
    <form class="mt-3"
          hx-post="/app/issues/@Model.Key/comments"
          hx-target="#comments-list-@Model.Key"
          hx-swap="innerHTML">
        <textarea name="body" rows="2" placeholder="Add a comment..." required class="mb-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm"></textarea>
        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Comment</button>
    </form>
</div>

<!-- Activity -->
<div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
    <h3 class="mb-3 text-sm font-semibold text-slate-900">Activity</h3>
    <div id="activity-@Model.Key"
         hx-get="/app/issues/@Model.Key/activity"
         hx-trigger="refreshActivity from:body"
         hx-swap="innerHTML">
        <partial name="Shared/_IssueActivity" model="Model.Activity" />
    </div>
</div>
