@model NimbusBoard.Application.Dashboard.Models.SprintPreviewViewModel
<div class="rounded-2xl border border-slate-100 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center justify-between gap-3">
        <div class="min-w-0">
            <h2 class="truncate text-base font-semibold text-slate-900">@Model.Name</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Goal))
            {
                <p class="truncate text-xs text-slate-500">@Model.Goal</p>
            }
        </div>
        <span class="shrink-0 rounded-full bg-sky-50 px-2.5 py-1 text-xs font-medium text-sky-700">@Model.DaysLeft days left</span>
    </div>
    <div class="grid grid-cols-3 gap-2">
        @foreach (var column in Model.Columns)
        {
            <div class="rounded-lg bg-slate-50 px-2.5 py-2">
                <div class="mb-1.5 flex items-center justify-between gap-1">
                    <span class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">@column.Name</span>
                    <span class="rounded-full bg-white px-1.5 py-0.5 text-[10px] text-slate-500">@column.Count</span>
                </div>
                @if (column.Cards.Any())
                {
                    var card = column.Cards.First();
                    <p class="truncate text-xs leading-snug text-slate-800 @(card.IsHighlighted ? "font-medium text-indigo-700" : "")">@card.Title</p>
                }
                else
                {
                    <p class="text-xs text-slate-400">—</p>
                }
            </div>
        }
    </div>
</div>
