@model NimbusBoard.Application.Dashboard.Models.SprintPreviewViewModel
<div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
    <div class="mb-5 flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold text-slate-900">@Model.Name</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Goal))
            {
                <p class="text-sm text-slate-500">@Model.Goal</p>
            }
        </div>
        <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-medium text-sky-700">@Model.DaysLeft days left</span>
    </div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        @foreach (var column in Model.Columns)
        {
            <div class="rounded-xl bg-slate-50 p-3">
                <div class="mb-3 flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">@column.Name</span>
                    <span class="rounded-full bg-white px-2 py-0.5 text-xs text-slate-500">@column.Count</span>
                </div>
                @foreach (var card in column.Cards)
                {
                    <div class="rounded-lg border @(card.IsHighlighted ? "border-indigo-300 bg-indigo-50" : "border-slate-200 bg-white") px-3 py-2 text-sm text-slate-800">
                        @card.Title
                    </div>
                }
            </div>
        }
    </div>
</div>
