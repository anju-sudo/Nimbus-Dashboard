@model IReadOnlyList<NimbusBoard.Application.Collaboration.Models.CommentViewModel>

@if (!Model.Any())
{
    <p class="text-sm text-slate-500">No comments yet.</p>
}
else
{
    <div class="space-y-3">
        @foreach (var comment in Model)
        {
            <div class="rounded-lg bg-white p-3 shadow-sm">
                <div class="mb-2 flex items-center gap-2">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-violet-100 text-xs font-semibold text-violet-700">@comment.AuthorInitials</span>
                    <span class="text-sm font-medium text-slate-900">@comment.AuthorName</span>
                    <span class="text-xs text-slate-400">@comment.TimeAgo</span>
                </div>
                <p class="text-sm text-slate-700">@comment.Body</p>
            </div>
        }
    </div>
}
