@model Nimbus_Board.Pages.App.Shared.KpiCardModel
<div class="rounded-xl border border-slate-100/80 @Model.BackgroundClass px-4 py-3 shadow-sm">
    <div class="@Model.IconClass mb-2">
        @switch (Model.Icon)
        {
            case Nimbus_Board.Pages.App.Shared.KpiIcon.List:
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
                </svg>
                break;
            case Nimbus_Board.Pages.App.Shared.KpiIcon.Progress:
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a9 9 0 1 1-9 9" />
                    <circle cx="12" cy="12" r="9" stroke-opacity="0.25" />
                </svg>
                break;
            case Nimbus_Board.Pages.App.Shared.KpiIcon.Done:
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                break;
            case Nimbus_Board.Pages.App.Shared.KpiIcon.Warning:
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008v.008H12v-.008ZM10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
                </svg>
                break;
            case Nimbus_Board.Pages.App.Shared.KpiIcon.Flame:
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
                </svg>
                break;
        }
    </div>
    <p class="text-2xl font-bold tracking-tight text-slate-900">@Model.Value</p>
    <p class="mt-0.5 text-xs font-medium text-slate-600">@Model.Label</p>
</div>
