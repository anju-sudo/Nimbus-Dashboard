@page "/app/settings"
@model Nimbus_Board.Pages.App.Settings.IndexModel

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Settings</h1>
    <p class="text-sm text-slate-500">Workspace profile and notification delivery</p>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Profile</h2>
        <dl class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Name</dt>
                <dd class="font-medium text-slate-900">Anjumol Babu</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Member ID</dt>
                <dd class="font-medium text-slate-900">1</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Workspace</dt>
                <dd class="font-medium text-slate-900">Acme</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Role</dt>
                <dd class="font-medium text-slate-900">Admin</dd>
            </div>
        </dl>
    </div>

    <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Email (SMTP)</h2>
        <dl class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Status</dt>
                <dd>
                    @if (Model.SmtpEnabled)
                    {
                        <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">Enabled</span>
                    }
                    else
                    {
                        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">Logging only</span>
                    }
                </dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Host</dt>
                <dd class="font-medium text-slate-900">@Model.SmtpHost</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">From</dt>
                <dd class="font-medium text-slate-900">@Model.SmtpFrom</dd>
            </div>
        </dl>
        <p class="mt-4 text-xs text-slate-500">Configure the <code>Smtp</code> section in appsettings to enable delivery.</p>
    </div>
</div>

@if (Model.Boards.Any())
{
    <div class="mt-6 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">Boards quick access</h2>
        <div class="flex flex-wrap gap-3">
            @foreach (var board in Model.Boards)
            {
                <a href="/app/boards/@board.Id"
                   class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700">
                    @board.Name
                </a>
            }
        </div>
    </div>
}
