@page "/app/projects"
@model Nimbus_Board.Pages.App.Projects.IndexModel

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Projects</h1>
        <p class="text-sm text-slate-500">Manage your workspaces and teams</p>
    </div>
    <a href="/app/projects/create" class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-indigo-700">+ New Project</a>
</div>

<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
    @foreach (var project in Model.Projects)
    {
        <a href="/app/projects/@project.Key" class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:border-indigo-200 hover:shadow-md">
            <div class="mb-3 flex items-center justify-between">
                <span class="rounded-lg bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700">@project.Key</span>
                <span class="text-xs text-slate-400">@project.MemberCount members</span>
            </div>
            <h2 class="mb-2 text-lg font-semibold text-slate-900">@project.Name</h2>
            <p class="mb-4 line-clamp-2 text-sm text-slate-500">@(project.Description ?? "No description")</p>
            <div class="flex items-center gap-2 text-sm text-slate-600">
                <span class="rounded-full bg-slate-100 px-2.5 py-1">@project.OpenIssues open issues</span>
            </div>
        </a>
    }
</div>
