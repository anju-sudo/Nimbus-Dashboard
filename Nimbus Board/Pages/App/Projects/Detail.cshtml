@page "/app/projects/{key}"
@model Nimbus_Board.Pages.App.Projects.DetailModel
@{
    var p = Model.Project!;
}

<div class="mb-6">
    <a href="/app/projects" class="text-sm text-indigo-600 hover:text-indigo-700">← Back to projects</a>
    <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <span class="rounded-lg bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700">@p.Key</span>
            <h1 class="mt-2 text-2xl font-bold text-slate-900">@p.Name</h1>
            <p class="text-sm text-slate-500">@(p.Description ?? "No description")</p>
        </div>
        <button type="button"
                hx-get="/app/issues/create?projectId=@p.Id"
                hx-target="#modal-root"
                hx-swap="innerHTML"
                class="rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-indigo-700">+ New Issue</button>
    </div>
</div>

<div class="mb-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Boards</h2>
        <div class="flex flex-wrap gap-3">
            @foreach (var board in p.Boards)
            {
                <a href="/app/boards/@board.Id" class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium hover:border-indigo-200 hover:bg-indigo-50">@board.Name</a>
            }
        </div>
    </div>
    <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Team</h2>
        <div class="space-y-3">
            @foreach (var member in p.Members)
            {
                <div class="flex items-center gap-3">
                    <span class="flex h-9 w-9 items-center justify-center rounded-full bg-violet-100 text-xs font-semibold text-violet-700">@member.Initials</span>
                    <div>
                        <p class="text-sm font-medium">@member.DisplayName</p>
                        <p class="text-xs text-slate-500">@member.Role</p>
                    </div>
                </div>
            }
        </div>
        <form method="post" asp-page-handler="AddMember" class="mt-6 space-y-3 border-t border-slate-100 pt-4">
            <input type="hidden" name="projectId" value="@p.Id" />
            <input name="displayName" placeholder="Name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required />
            <input name="initials" placeholder="Initials" maxlength="3" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required />
            <select name="role" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                <option value="Member">Member</option>
                <option value="Admin">Admin</option>
                <option value="Viewer">Viewer</option>
            </select>
            <button type="submit" class="w-full rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white">Add member</button>
        </form>
    </div>
</div>

<div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Recent issues</h2>
    <div class="space-y-2">
        @foreach (var issue in p.RecentIssues)
        {
            <a href="/app/issues/@issue.Key" class="flex items-center justify-between rounded-xl border border-slate-100 px-4 py-3 hover:bg-slate-50">
                <div class="flex items-center gap-3">
                    <span class="text-sm font-semibold text-indigo-600">@issue.Key</span>
                    <span class="text-sm text-slate-800">@issue.Title</span>
                </div>
                <span class="text-xs text-slate-500">@issue.Status</span>
            </a>
        }
    </div>
</div>

<div id="modal-root"></div>
