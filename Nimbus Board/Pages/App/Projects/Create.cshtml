@page "/app/projects/create"
@model Nimbus_Board.Pages.App.Projects.CreateModel

<div class="mx-auto max-w-lg">
    <a href="/app/projects" class="text-sm text-indigo-600">← Back</a>
    <h1 class="mt-3 mb-6 text-2xl font-bold">Create project</h1>
    <form method="post" class="space-y-4 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
        <div>
            <label class="mb-1 block text-sm font-medium">Project key</label>
            <input asp-for="Input.Key" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm uppercase" placeholder="NIM" required />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">Name</label>
            <input asp-for="Input.Name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">Description</label>
            <textarea asp-for="Input.Description" rows="3" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm"></textarea>
        </div>
        <button type="submit" class="w-full rounded-xl bg-indigo-600 py-2.5 text-sm font-medium text-white">Create project</button>
    </form>
</div>
