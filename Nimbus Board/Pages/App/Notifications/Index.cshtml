@page "/app/notifications"
@model Nimbus_Board.Pages.App.Notifications.IndexModel

<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Notifications</h1>
        <p class="text-sm text-slate-500">Real-time updates for assignments, comments, and sprints</p>
    </div>
    <form method="post" asp-page-handler="MarkAllRead">
        <button type="submit" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
            Mark all as read
        </button>
    </form>
</div>

<div class="rounded-2xl border border-slate-100 bg-white shadow-sm">
    @if (!Model.Notifications.Any())
    {
        <p class="p-8 text-center text-sm text-slate-500">You're all caught up.</p>
    }
    else
    {
        <div class="divide-y divide-slate-100">
            @foreach (var item in Model.Notifications)
            {
                <div class="flex items-start justify-between gap-4 px-6 py-4 @(item.IsRead ? "bg-white" : "bg-sky-50/60")">
                    <div>
                        <p class="text-sm font-medium text-slate-900">@item.Message</p>
                        <p class="mt-1 text-xs text-slate-500">@item.Type · @item.TimeAgo</p>
                        @if (!string.IsNullOrWhiteSpace(item.LinkUrl))
                        {
                            <a href="@item.LinkUrl" class="mt-2 inline-block text-sm text-indigo-600 hover:text-indigo-700">Open</a>
                        }
                    </div>
                    @if (!item.IsRead)
                    {
                        <form method="post" asp-page-handler="MarkRead">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="text-xs font-medium text-slate-500 hover:text-indigo-600">Mark read</button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</div>
